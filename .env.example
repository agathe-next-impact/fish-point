# ============================================================================
# fish-point — variables d'environnement
# ----------------------------------------------------------------------------
# Copier ce fichier vers .env.local et renseigner les valeurs.
# .env.local est gitignored.
# ============================================================================

# --- Base ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Database (Postgres + PostGIS) ---
# En local : docker compose up -d, puis :
DATABASE_URL="postgresql://fishspot:fishspot@localhost:5433/fishspot?schema=public"
# En prod Vercel/Neon : l'integration peut fournir une URL dediee Prisma.
# Si elle existe, elle est prioritaire sur DATABASE_URL pour le runtime.
FISHPOINT_POSTGRES_PRISMA_URL=""
FISHPOINT_DATABASE_URL=""
FISHPOINT_POSTGRES_URL=""
# Pour les migrations Prisma, privilegier une URL directe/non-pooler.
# Si ces variables sont absentes mais qu'une URL Neon "*-pooler" existe,
# prisma.config.ts derive automatiquement le host direct en retirant "-pooler".
FISHPOINT_POSTGRES_URL_NON_POOLING=""
FISHPOINT_DATABASE_URL_UNPOOLED=""

# --- NextAuth ---
# Générer : openssl rand -base64 32
AUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Cron (Vercel Crons) ---
# Générer : openssl rand -hex 32
CRON_SECRET=""

# --- MapLibre + Protomaps ---
# Marqueur de provider — défaut 'maplibre' depuis ML-05.
# Conservé jusqu'à ML-07 (cleanup final).
NEXT_PUBLIC_MAP_PROVIDER="maplibre"
# URL publique de Vercel Blob (base, sans /western-europe.pmtiles)
# Ex : https://abcd1234.public.blob.vercel-storage.com
NEXT_PUBLIC_PMTILES_URL=""
# Nom du fichier PMTiles dans Vercel Blob
NEXT_PUBLIC_PMTILES_FILE="western-europe.pmtiles"
# Token write Vercel Blob — auto-provisionné par `vercel env pull .env.local`
BLOB_READ_WRITE_TOKEN=""

# --- Cloudflare R2 (images uniquement — migration future trackée dans tech-debt.md) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="fishspot-images"
NEXT_PUBLIC_R2_PUBLIC_URL=""

# --- Upstash Redis (rate-limit + cache) ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Stripe (abonnements premium) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PREMIUM_PRICE_ID=""

# --- Resend (emails) ---
RESEND_API_KEY=""

# --- APIs externes ---
OPENWEATHERMAP_API_KEY=""
UNSPLASH_ACCESS_KEY=""
GOOGLE_CLOUD_VISION_API_KEY=""
HUBEAU_BASE_URL="https://hubeau.eaufrance.fr/api"

# --- Mobile (Expo) ---
EXPO_PUBLIC_API_URL="http://localhost:3000"
EXPO_PUBLIC_PROJECT_ID=""
EXPO_PUBLIC_PMTILES_URL=""
